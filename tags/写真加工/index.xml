			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;自動編集&lt;/td&gt;
					&lt;td&gt;AIが自動で写真を編集する&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;手動編集&lt;/td&gt;
					&lt;td&gt;ユーザーが手動で写真を編集する&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;ハイブリッド編集&lt;/td&gt;
					&lt;td&gt;AIとユーザーが協力して写真を編集する&lt;/td&gt;
			&lt;/tr&gt;
