 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th&gt;失敗&lt;/th&gt;
 &lt;th&gt;対策&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
