 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td&gt;ChatGPTの使い方&lt;/td&gt;
 &lt;td&gt;ChatGPT&lt;/td&gt;
