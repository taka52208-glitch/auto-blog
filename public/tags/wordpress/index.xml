			&lt;tr&gt;
					&lt;th&gt;AIツール&lt;/th&gt;
					&lt;th&gt;価格&lt;/th&gt;
					&lt;th&gt;無料プラン&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
